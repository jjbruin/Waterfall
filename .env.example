# Waterfall XIRR — Environment Configuration
# Copy to .env and fill in values. Never commit .env to git.

# Flask
FLASK_ENV=development
SECRET_KEY=change-this-to-a-random-32-byte-string
JWT_SECRET=change-this-to-a-different-random-string

# Database
# SQLite (default — local development)
DB_PATH=waterfall.db
# PostgreSQL (team/production — uncomment and set)
# DATABASE_URL=postgresql://user:password@host:5432/waterfall_xirr

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5173

# MRI API (leave empty to use local database)
# MRI_API_BASE=https://mri.yourcompany.com/api
# MRI_API_TOKEN=

# SSO (leave all commented out to use username/password auth only)
# SSO_PROVIDER=azure          # "azure" or "okta"
# SSO_CLIENT_ID=your-client-id
# SSO_CLIENT_SECRET=your-client-secret
# SSO_TENANT_ID=your-azure-tenant-id     # Azure AD only
# SSO_ISSUER=https://yourorg.okta.com    # Okta only
# SSO_DEFAULT_ROLE=viewer                 # Role for new SSO users
# SSO_REDIRECT_URL=/                      # Where to redirect after SSO
